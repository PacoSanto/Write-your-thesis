% ============================================================
% BIBLIOGRAPHY FILE — references.bib
%
% Add your references here. Each entry needs a unique label
% (e.g., Smith2020) that you use in \cite{Smith2020}.
%
% TIP: Most reference managers (Zotero, Mendeley, EndNote)
% and Google Scholar can export entries in BibTeX format.
% Just copy-paste them here.
%
% COMPILATION: After adding new entries, run:
%   LuaLaTeX -> Biber -> LuaLaTeX -> LuaLaTeX
% ============================================================


% --- EXAMPLE: Journal article ---
@article{Smith2020,
  author   = {Smith, John A. and Doe, Jane B.},
  title    = {A comprehensive review of sample preparation techniques},
  journal  = {Journal of Analytical Chemistry},
  year     = {2020},
  volume   = {128},
  number   = {3},
  pages    = {450--467},
  doi      = {10.1000/example-doi-001},
}

% --- EXAMPLE: Book ---
@book{Eco1977,
  author    = {Eco, Umberto},
  title     = {Come si fa una tesi di laurea},
  publisher = {Bompiani},
  year      = {1977},
  address   = {Milano},
}

% --- EXAMPLE: Book chapter ---
@incollection{Brown2018,
  author    = {Brown, Alice C.},
  title     = {Mineralogical analysis of clay-rich sediments},
  booktitle = {Advances in Applied Mineralogy},
  editor    = {White, Robert D.},
  publisher = {Springer},
  year      = {2018},
  pages     = {100--120},
  doi       = {10.1000/example-doi-002},
}

% --- EXAMPLE: Conference proceedings ---
@inproceedings{Garcia2019,
  author    = {Garcia, Maria and Lopez, Carlos},
  title     = {New approaches to {XRF} calibration for geological samples},
  booktitle = {Proceedings of the 14th International Conference on Geochemistry},
  year      = {2019},
  pages     = {33--37},
  address   = {Vienna, Austria},
}

% --- EXAMPLE: PhD Thesis ---
@phdthesis{Johnson2021,
  author = {Johnson, Emily R.},
  title  = {Geochemical fingerprinting of volcanic deposits in Southern {Italy}},
  school = {University of Cambridge},
  year   = {2021},
}

% --- EXAMPLE: Online resource / website ---
@online{USGS2023,
  author  = {{U.S. Geological Survey}},
  title   = {Mineral Commodity Summaries 2023},
  year    = {2023},
  url     = {https://www.usgs.gov/centers/national-minerals-information-center},
  urldate = {2024-01-15},
}


